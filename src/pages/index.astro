---
export const prerender = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const name = data.get("name") || "Не указано";
    const phone = data.get("phone") || "Не указано";
    const country = data.get("country") || "Не указано";
    const token = import.meta.env.TELEGRAM_BOT_TOKEN || import.meta.env.TELEGRAM_TOKEN;
    const chatId = import.meta.env.TELEGRAM_CHAT_ID;
    const text = `🚀 НОВАЯ ЗАЯВКА!\n👤 Имя: ${name}\n📞 Тел: ${phone}\n🌍 Куда: ${country}`;
    const response = await fetch(`https://api.telegram.org/bot${token}/sendMessage`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ chat_id: chatId, text: text }),
    });
    if (response.ok) {
      return Astro.redirect("/?done=true");
    } else {
      const errorData = await response.json();
      console.error("Ошибка от Telegram API:", errorData);
    }
  } catch (e) {
    console.error("Критическая ошибка на сервере:", e);
  }
}
const done = Astro.url.searchParams.get("done");
---

<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BON VOYAGE | Визовое агентство в Алматы</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --o: #e8751a;
      --o2: #d4a843;
      --og: rgba(232,117,26,0.3);
      --gold: #c8a94a;
      --gold2: #e8c96a;
      --bg: #1c2818;
      --bg2: #212e1c;
      --bg3: #181f14;
      --card: rgba(16,24,12,0.97);
      --brd: rgba(180,150,60,0.2);
      --txt: #f0ead8;
      --mt: #8a9070;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--txt);font-family:'Montserrat',sans-serif;overflow-x:hidden}

    /* HEADER */
    header{
      position:fixed;top:0;width:100%;z-index:1000;
      display:flex;justify-content:space-between;align-items:center;
      padding:12px 6%;
      background:rgba(16,22,12,0.97);
      backdrop-filter:blur(14px);
      border-bottom:1px solid var(--brd);
    }
    .logo{display:flex;align-items:center;gap:11px;cursor:pointer;text-decoration:none}
    .logo-icon{width:46px;height:46px;flex-shrink:0}
    .logo-text{display:flex;flex-direction:column;line-height:1}
    .logo-bon{font-size:20px;font-weight:900;letter-spacing:.05em;color:#fff}
    .logo-sub{font-size:10px;font-weight:600;letter-spacing:.22em;color:var(--mt);text-transform:uppercase;margin-top:2px}
    nav{display:flex;align-items:center;gap:24px}
    nav a{color:var(--mt);text-decoration:none;font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;transition:color .3s}
    nav a:hover{color:var(--gold)}
    .nbtn{
      background:var(--o);color:#fff!important;padding:9px 20px;border-radius:3px;
      font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
      text-decoration:none;box-shadow:0 0 16px var(--og);
      transition:background .3s,box-shadow .3s!important;
    }
    .nbtn:hover{background:var(--o2)!important;box-shadow:0 0 26px var(--og)!important}
    .burger{display:none;flex-direction:column;gap:5px;cursor:pointer}
    .burger span{width:24px;height:2px;background:var(--gold);display:block}

    /* HERO */
    .hero{
      position:relative;min-height:100vh;
      display:flex;align-items:center;
      padding:120px 6% 70px;overflow:hidden;
      background:#181f14;
    }
    .hero-grad{
      position:absolute;inset:0;z-index:0;
      background:radial-gradient(ellipse 90% 90% at 65% 50%,rgba(38,55,28,0.85) 0%,rgba(18,26,12,1) 65%);
    }
    .hero-grid{
      position:absolute;inset:0;z-index:1;
      background-image:
        linear-gradient(rgba(180,150,60,.03) 1px,transparent 1px),
        linear-gradient(90deg,rgba(180,150,60,.03) 1px,transparent 1px);
      background-size:55px 55px;
    }

    /* КАРТА МИРА */
    .wmap-wrap{position:absolute;right:0;top:50%;transform:translateY(-50%);width:58%;z-index:2;pointer-events:none;opacity:.58}
    .wmap-wrap svg{width:100%;height:auto}
    @keyframes mapglow{0%,100%{filter:drop-shadow(0 0 18px rgba(200,169,74,.22))}50%{filter:drop-shadow(0 0 32px rgba(200,169,74,.42))}}
    
    .wmap-svg{
      animation:mapglow 4s ease-in-out infinite;
      shape-rendering: geometricPrecision; /* Четкость */
    }
    .wmap-svg path { transition: all 0.3s ease; }

    /* ТОЧКИ ГОРОДОВ */
    .mdot{position:absolute;z-index:4;pointer-events:none}
    .mdot-inner{width:9px;height:9px;border-radius:50%;position:relative}
    .mdot-ring{position:absolute;inset:-5px;border-radius:50%;border:1.5px solid currentColor;opacity:.5;animation:mring 2s ease-in-out infinite}
    .mdot-ring2{position:absolute;inset:-10px;border-radius:50%;border:1px solid currentColor;opacity:.25;animation:mring 2s ease-in-out infinite .4s}
    @keyframes mring{0%{transform:scale(1);opacity:.5}100%{transform:scale(1.8);opacity:0}}
    .dot-label{position:absolute;top:-22px;left:50%;transform:translateX(-50%);font-size:9px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;white-space:nowrap;color:var(--gold2);text-shadow:0 1px 4px rgba(0,0,0,.8)}
    .routes-svg{position:absolute;inset:0;width:100%;height:100%;z-index:3;pointer-events:none}

    /* ПАНЕЛИ */
    .dpanels{position:absolute;right:4.5%;top:50%;transform:translateY(-50%);z-index:5;display:flex;flex-direction:column;gap:10px;pointer-events:none}
    .dp{background:rgba(14,20,10,.9);border:1px solid rgba(180,150,60,.28);border-left:3px solid var(--o);padding:9px 15px;min-width:155px;backdrop-filter:blur(8px);border-radius:2px}
    .dp-l{font-size:9px;font-weight:600;letter-spacing:.11em;text-transform:uppercase;color:var(--mt);margin-bottom:5px}
    .dp-bar{height:3px;background:rgba(180,150,60,.2);border-radius:2px;margin-bottom:4px;overflow:hidden}
    .dp-fill{height:100%;background:linear-gradient(90deg,var(--o),var(--gold));border-radius:2px}
    .dp-v{font-size:12px;font-weight:700;color:var(--txt)}

    .hcont{position:relative;z-index:5;display:grid;grid-template-columns:1fr 385px;gap:56px;width:100%;align-items:center}
    .hbadge{display:inline-flex;align-items:center;gap:9px;background:rgba(200,169,74,.1);border:1px solid rgba(200,169,74,.38);padding:6px 14px;border-radius:2px;font-size:11px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:var(--gold2);margin-bottom:20px;animation:up .7s .1s ease both}
    .hbadge b{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--o);box-shadow:0 0 7px var(--o);animation:blink 2s infinite}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
    h1{font-size:clamp(30px,4.2vw,65px);font-weight:900;line-height:1.06;text-transform:uppercase;animation:up .7s .2s ease both}
    h1 em{font-style:normal;color:var(--o);text-shadow:0 0 32px rgba(232,117,26,.4)}
    .hdesc{font-size:14px;line-height:1.8;color:var(--mt);margin-top:20px;max-width:470px;border-left:3px solid var(--gold);padding-left:15px;animation:up .7s .35s ease both}
    .hstats{display:flex;gap:34px;margin-top:38px;animation:up .7s .5s ease both}
    .sn{font-size:35px;font-weight:900;color:var(--o);line-height:1;text-shadow:0 0 16px var(--og)}
    .sl{font-size:10px;font-weight:700;letter-spacing:.1em;color:var(--mt);text-transform:uppercase;margin-top:5px}
    @keyframes up{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

    /* ФОРМА */
    .fcard{background:var(--card);border:1px solid var(--brd);border-top:3px solid var(--o);padding:34px 30px;backdrop-filter:blur(18px);box-shadow:0 20px 55px rgba(0,0,0,.6),0 0 22px rgba(200,169,74,.06);border-radius:4px;animation:up .7s .3s ease both}
    .ft{font-size:18px;font-weight:800;text-transform:uppercase;letter-spacing:.05em;text-align:center;margin-bottom:4px}
    .fs{text-align:center;font-size:11px;font-weight:600;letter-spacing:.12em;color:var(--o);text-transform:uppercase;margin-bottom:22px}
    .ig{margin-bottom:11px}
    .ig input,.ig select{width:100%;background:rgba(255,255,255,.04);border:1px solid rgba(180,150,60,.22);color:var(--txt);padding:13px 14px;font-family:'Montserrat',sans-serif;font-size:13px;font-weight:500;outline:none;transition:border-color .3s,background .3s;-webkit-appearance:none;border-radius:3px}
    .ig input::placeholder{color:var(--mt)}
    .ig input:focus,.ig select:focus{border-color:var(--o);background:rgba(232,117,26,.05)}
    .ig select option{background:#141e10;color:var(--txt)}
    .fbtn{width:100%;background:var(--o);color:#fff;border:none;padding:15px;font-family:'Montserrat',sans-serif;font-size:13px;font-weight:800;letter-spacing:.13em;text-transform:uppercase;cursor:pointer;margin-top:4px;border-radius:3px;box-shadow:0 4px 16px var(--og);transition:background .3s,box-shadow .3s,transform .15s}
    .fbtn:hover{background:var(--o2);box-shadow:0 6px 26px rgba(232,117,26,.5);transform:translateY(-2px)}
    .fbtn:active{transform:translateY(0)}
    .fnote{text-align:center;font-size:10px;letter-spacing:.07em;color:var(--mt);margin-top:9px}
    .swrap{text-align:center;padding:16px 0}
    .sico{width:60px;height:60px;border:2px solid var(--o);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:24px;color:var(--o);box-shadow:0 0 26px var(--og)}
    .sttl{font-size:24px;font-weight:900;text-transform:uppercase;color:var(--o);margin-bottom:8px}
    .stxt{color:var(--mt);font-size:14px;line-height:1.7}
    .sback{display:inline-block;margin-top:18px;color:var(--o);text-decoration:none;font-size:11px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;border-bottom:1px solid var(--o);padding-bottom:2px}

    .divl{height:1px;background:linear-gradient(90deg,transparent,rgba(200,169,74,.3),transparent)}

    /* СЕКЦИИ */
    .sec{padding:85px 6%}
    .sec.alt{background:var(--bg2)}
    .sec.dark{background:var(--bg3)}
    .stag{display:inline-flex;align-items:center;gap:9px;font-size:11px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:11px}
    .stag::before{content:'';width:24px;height:2px;background:var(--gold)}
    .sectitle{font-size:clamp(25px,3.2vw,42px);font-weight:900;text-transform:uppercase;line-height:1.1;margin-bottom:16px}
    .sectitle span{color:var(--o)}
    .secdesc{font-size:14px;line-height:1.8;color:var(--mt);max-width:700px;margin-bottom:46px}

    /* FLAGS */
    .flags-sec{padding:50px 0;background:var(--bg3);overflow:hidden;border-top:1px solid var(--brd);border-bottom:1px solid var(--brd)}
    .flags-label{font-size:14px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--mt);text-align:center}
    .flags-wrap{overflow:hidden;position:relative;margin-top:20px}
    .flags-wrap::before,.flags-wrap::after{content:'';position:absolute;top:0;bottom:0;width:60px;z-index:2;pointer-events:none}
    .flags-wrap::before{left:0;background:linear-gradient(90deg,var(--bg3),transparent)}
    .flags-wrap::after{right:0;background:linear-gradient(-90deg,var(--bg3),transparent)}
    .flags-track{display:flex;gap:20px;animation:scrollf 30s linear infinite;width:max-content}
    .flags-track:hover{animation-play-state:paused}
    @keyframes scrollf{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .flag-item{display:flex;flex-direction:column;align-items:center;gap:10px;flex-shrink:0;width:80px}
    .flag-item .fi{width:42px;height:28px;object-fit:cover;border-radius:3px;border:1px solid rgba(200,169,74,.2)}
    .flag-item span{font-size:10px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--mt);text-align:center}

    /* WHY US */
    .why-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
    .why-card{background:rgba(22,34,16,.7);border:1px solid var(--brd);padding:32px 24px;border-radius:4px;text-align:center;transition:border-color .3s,transform .3s}
    .why-card:hover{border-color:rgba(200,169,74,.45);transform:translateY(-4px)}
    .why-icon{font-size:38px;margin-bottom:16px;display:block}
    .why-num{font-size:32px;font-weight:900;color:var(--o);line-height:1;text-shadow:0 0 14px var(--og)}
    .why-label{font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--mt);margin-top:6px}
    .why-text{font-size:13px;line-height:1.7;color:var(--mt);margin-top:10px}

    /* STEPS */
    .steps{display:grid;grid-template-columns:repeat(5,1fr);gap:0;position:relative;margin-top:10px}
    .steps::before{content:'';position:absolute;top:28px;left:10%;right:10%;height:2px;background:linear-gradient(90deg,var(--o),var(--gold));opacity:.3;z-index:0}
    .step{text-align:center;padding:0 16px;position:relative;z-index:1}
    .step-num{width:56px;height:56px;border-radius:50%;background:var(--o);color:#fff;font-size:20px;font-weight:900;display:flex;align-items:center;justify-content:center;margin:0 auto 18px;box-shadow:0 0 20px var(--og)}
    .step-title{font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:var(--txt);margin-bottom:8px}
    .step-desc{font-size:12px;line-height:1.7;color:var(--mt)}

    /* SERVICES */
    .sgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
    .sc{background:rgba(22,34,16,.88);border:1px solid var(--brd);padding:36px 28px;border-radius:4px;position:relative;overflow:hidden;transition:border-color .3s,transform .3s,box-shadow .3s}
    .sc::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--o),var(--gold),transparent);transform:scaleX(0);transform-origin:left;transition:transform .4s}
    .sc:hover{border-color:rgba(200,169,74,.4);transform:translateY(-5px);box-shadow:0 14px 34px rgba(0,0,0,.4)}
    .sc:hover::before{transform:scaleX(1)}
    .sc-flag{font-size:28px;margin-bottom:12px;display:block}
    .scname{font-size:19px;font-weight:800;text-transform:uppercase;letter-spacing:.04em;color:var(--txt);margin-bottom:10px}
    .scdesc{font-size:13px;line-height:1.75;color:var(--mt)}
    .sc-countries{display:flex;flex-wrap:wrap;gap:6px;margin-top:16px}
    .sc-countries span{background:rgba(200,169,74,.1);border:1px solid rgba(200,169,74,.3);padding:3px 10px;border-radius:2px;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--gold2)}
    .sc-list{margin-top:14px;padding-left:0;list-style:none}
    .sc-list li{font-size:12px;line-height:1.8;color:var(--mt);display:flex;align-items:flex-start;gap:8px}
    .sc-list li::before{content:'→';color:var(--gold);flex-shrink:0;margin-top:1px}

    /* VISA TYPES */
    .vtypes{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
    .vt{background:rgba(22,34,16,.7);border:1px solid var(--brd);border-left:4px solid var(--o);padding:28px 24px;border-radius:4px;transition:transform .3s,box-shadow .3s}
    .vt:hover{transform:translateY(-3px);box-shadow:0 10px 30px rgba(0,0,0,.3)}
    .vt-title{font-size:16px;font-weight:800;text-transform:uppercase;color:var(--txt);margin-bottom:10px;display:flex;align-items:center;gap:10px}
    .vt-title span{font-size:20px}
    .vt-desc{font-size:13px;line-height:1.8;color:var(--mt)}
    .vt-list{margin-top:12px;padding-left:0;list-style:none}
    .vt-list li{font-size:12px;line-height:1.8;color:var(--mt);display:flex;align-items:flex-start;gap:8px}
    .vt-list li::before{content:'✓';color:var(--gold);flex-shrink:0;font-weight:700}

    /* DOCS */
    .docs-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
    .doc-block{background:rgba(22,34,16,.7);border:1px solid var(--brd);padding:28px;border-radius:4px}
    .doc-block h3{font-size:16px;font-weight:800;text-transform:uppercase;color:var(--gold);margin-bottom:16px;display:flex;align-items:center;gap:10px}
    .doc-list{list-style:none;padding:0}
    .doc-list li{font-size:13px;line-height:1.9;color:var(--mt);display:flex;align-items:flex-start;gap:10px;border-bottom:1px solid rgba(180,150,60,.12);padding-bottom:8px;margin-bottom:8px}
    .doc-list li:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
    .doc-list li::before{content:'📄';flex-shrink:0}

    /* FAQ */
    .faq{display:flex;flex-direction:column;gap:12px}
    .faq-item{background:rgba(22,34,16,.7);border:1px solid var(--brd);border-radius:4px;overflow:hidden}
    .faq-q{padding:18px 24px;font-size:14px;font-weight:700;color:var(--txt);cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:16px}
    .faq-q::after{content:'+';color:var(--gold);font-size:20px;font-weight:300;flex-shrink:0;transition:transform .3s}
    .faq-item.open .faq-q::after{transform:rotate(45deg)}
    .faq-a{padding:0 24px;max-height:0;overflow:hidden;transition:max-height .4s ease,padding .3s}
    .faq-item.open .faq-a{max-height:300px;padding:0 24px 18px}
    .faq-a p{font-size:13px;line-height:1.8;color:var(--mt)}

    /* REVIEWS */
    .rgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
    .rv{background:rgba(22,34,16,.7);border:1px solid var(--brd);padding:32px 28px;border-radius:4px;transition:border-color .3s,transform .3s}
    .rv:hover{border-color:rgba(200,169,74,.38);transform:translateY(-4px)}
    .rv-stars{color:var(--gold);font-size:16px;margin-bottom:14px;letter-spacing:2px}
    .rv-text{font-size:13px;line-height:1.75;color:var(--mt);margin-bottom:18px;font-style:italic}
    .rv-author{display:flex;align-items:center;gap:12px}
    .rv-avatar{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--o),#3a6a24);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:800;color:#fff;flex-shrink:0}
    .rv-name{font-size:13px;font-weight:700;color:var(--txt)}
    .rv-country{font-size:11px;color:var(--mt);margin-top:2px}

    /* CONTACTS */
    .cgrid{display:grid;grid-template-columns:1fr 2fr;gap:60px;margin-top:46px;align-items:start}
    .cb{margin-bottom:30px}
    .cb:last-child{margin-bottom:0}
    .clabel{font-size:10px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:7px}
    .cval{font-size:16px;font-weight:600;line-height:1.5;color:var(--txt)}
    .csub{font-size:12px;color:var(--mt);margin-top:3px}
    .mapbox{position:relative;height:400px;overflow:hidden;border:1px solid var(--brd);border-radius:4px}
    .mapbox::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--o),var(--gold),transparent);z-index:2}
    .mapbox iframe{width:100%;height:100%;border:none;filter:saturate(.18) brightness(.5) hue-rotate(80deg)}

    /* CTA */
    .cta-banner{
      padding:70px 6%;background:linear-gradient(108deg,rgba(22,36,14,.95),rgba(16,26,10,.98));
      border-top:1px solid var(--brd);border-bottom:1px solid var(--brd);
      text-align:center;position:relative;overflow:hidden;
    }
    .cta-banner::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 50% 50%,rgba(200,169,74,.07),transparent);pointer-events:none}
    .cta-banner h2{font-size:clamp(24px,3vw,40px);font-weight:900;text-transform:uppercase;margin-bottom:16px}
    .cta-banner h2 span{color:var(--o)}
    .cta-banner p{font-size:15px;line-height:1.8;color:var(--mt);max-width:600px;margin:0 auto 32px}
    .cta-btn{display:inline-block;background:var(--o);color:#fff;padding:16px 40px;border-radius:3px;font-size:14px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;box-shadow:0 6px 24px var(--og);transition:background .3s,transform .2s}
    .cta-btn:hover{background:var(--o2);transform:translateY(-2px)}

    /* FOOTER */
    footer{padding:22px 6%;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--brd);background:rgba(10,14,8,.97);gap:20px}
    .flogo{display:flex;align-items:center;gap:10px;text-decoration:none}
    .flogo-bon{font-size:16px;font-weight:900;letter-spacing:.05em;color:#fff}
    .flogo-sub{font-size:9px;font-weight:600;letter-spacing:.22em;color:var(--mt);text-transform:uppercase;margin-top:1px}
    .fcopy{font-size:12px;color:var(--mt);font-weight:500}

    @media(max-width:1200px){.why-grid{grid-template-columns:repeat(2,1fr)}.steps{grid-template-columns:repeat(3,1fr)}.steps::before{display:none}}
    @media(max-width:1100px){
      .hcont{grid-template-columns:1fr;gap:42px}
      .dpanels,.mdot,.routes-svg{display:none}
      .wmap-wrap{width:100%;opacity:.1;top:auto;bottom:0;transform:none}
      .fcard{max-width:500px;width:100%}
      .sgrid{grid-template-columns:1fr}
      .vtypes{grid-template-columns:1fr}
      .docs-grid{grid-template-columns:1fr}
      .rgrid{grid-template-columns:1fr}
      .cgrid{grid-template-columns:1fr;gap:40px}
    }
    @media(max-width:768px){
      header{padding:11px 5%}
      nav{display:none}
      nav.open{display:flex;flex-direction:column;position:fixed;inset:0;background:rgba(12,18,8,.99);align-items:center;justify-content:center;gap:22px;z-index:999}
      nav.open a{font-size:15px;color:var(--txt)}
      .burger{display:flex;z-index:1001}
      .hero{padding:92px 5% 52px}
      h1{font-size:clamp(28px,8vw,42px)}
      .hstats{gap:22px;flex-wrap:wrap}
      .sec{padding:62px 5%}
      .why-grid,.steps{grid-template-columns:1fr}
      .sc,.rv{padding:26px 20px}
      .mapbox{height:240px}
      .fcard{padding:28px 18px}
      footer{flex-direction:column;text-align:center;padding:18px 5%;gap:10px}
    }
  </style>
</head>
<body>

<header>
  <a class="logo" href="#home">
    <svg class="logo-icon" viewBox="0 0 46 46" fill="none">
      <circle cx="23" cy="23" r="20" stroke="#c8a94a" stroke-width="1" opacity="0.4"/>
      <ellipse cx="23" cy="23" rx="20" ry="9" stroke="#4a7a30" stroke-width="1.5" fill="none" transform="rotate(-30 23 23)" opacity="0.8"/>
      <ellipse cx="23" cy="23" rx="12" ry="5" stroke="#e8751a" stroke-width="1.2" fill="none" transform="rotate(-30 23 23)" opacity="0.6"/>
      <g transform="translate(23,23) rotate(-35) translate(-8,-5)">
        <path d="M0,5 L14,2 L16,5 L14,8 Z" fill="#ffffff"/>
        <path d="M4,5 L0,0 L2,5 Z" fill="#e8dfc0" opacity="0.9"/>
        <path d="M4,5 L0,10 L2,5 Z" fill="#e8dfc0" opacity="0.9"/>
      </g>
      <circle cx="23" cy="23" r="2.5" fill="#e8751a" opacity="0.7"/>
    </svg>
    <div class="logo-text">
      <span class="logo-bon">BON <span style="color:var(--o)">VOYAGE</span></span>
      <span class="logo-sub">Визовое агентство</span>
    </div>
  </a>
  <nav id="nav">
    <a href="#home">Главная</a>
    <a href="#services">Услуги</a>
    <a href="#how">Как работаем</a>
    <a href="#docs">Документы</a>
    <a href="#reviews">Отзывы</a>
    <a href="#contacts">Контакты</a>
    <a href="#home" class="nbtn">Оставить заявку</a>
  </nav>
  <div class="burger" id="burger" onclick="toggleNav()"><span></span><span></span><span></span></div>
</header>

<section class="hero" id="home">
  <div class="hero-grad"></div>
  <div class="hero-grid"></div>

  <div class="wmap-wrap">
    <svg class="wmap-svg" viewBox="0 0 1000 500" xmlns="http://www.w3.org/2000/svg">
      <path d="M150,140 L170,130 L210,135 L230,170 L200,210 L170,200 L150,170 Z M420,130 L470,110 L520,120 L550,160 L500,210 L440,190 Z M620,80 C720,60 820,100 850,230 C720,330 620,300 590,260 Z M270,330 L370,320 L420,400 L320,500 L250,450 Z M750,430 L880,410 L920,500 L800,530 Z" fill="#c8a94a" opacity="0.3"/>
      <path d="M580,110 L610,105 L640,115 L650,135 L625,150 L585,145 Z" fill="#e8751a" opacity="0.9">
        <animate attributeName="opacity" values="0.7;1;0.7" dur="3s" repeatCount="indefinite" />
      </path>
    </svg>
  </div>

  <div class="mdot" style="right:40%;top:32%">
    <div class="mdot-inner" style="background:#e8751a;box-shadow:0 0 10px #e8751a;color:#e8751a">
      <div class="mdot-ring"></div><div class="mdot-ring2"></div>
    </div>
    <div class="dot-label">Алматы</div>
  </div>
  <div class="mdot" style="right:54%;top:22%"><div class="mdot-inner" style="background:#c8a94a;color:#c8a94a"><div class="mdot-ring"></div></div></div>
  <div class="mdot" style="right:79%;top:30%"><div class="mdot-inner" style="background:#c8a94a;color:#c8a94a"><div class="mdot-ring"></div></div></div>
  <div class="mdot" style="right:16%;top:26%"><div class="mdot-inner" style="background:#c8a94a;color:#c8a94a"><div class="mdot-ring"></div></div></div>

  <svg class="routes-svg" viewBox="0 0 100 100" preserveAspectRatio="none">
    <path d="M 60 32 Q 54 25 46 22" stroke="rgba(200,169,74,0.35)" stroke-width=".2" fill="none" stroke-dasharray=".6,.8"/>
    <path d="M 60 32 Q 40 20 21 30" stroke="rgba(200,169,74,0.22)" stroke-width=".2" fill="none" stroke-dasharray=".6,1"/>
    <path d="M 60 32 Q 72 28 84 26" stroke="rgba(200,169,74,0.3)" stroke-width=".2" fill="none" stroke-dasharray=".6,.8"/>
  </svg>

  <div class="dpanels">
    <div class="dp"><div class="dp-l">Шенген · одобрений</div><div class="dp-bar"><div class="dp-fill" style="width:94%"></div></div><div class="dp-v">94%</div></div>
    <div class="dp"><div class="dp-l">США · одобрений</div><div class="dp-bar"><div class="dp-fill" style="width:87%"></div></div><div class="dp-v">87%</div></div>
    <div class="dp"><div class="dp-l">Азия · одобрений</div><div class="dp-bar"><div class="dp-fill" style="width:98%"></div></div><div class="dp-v">98%</div></div>
  </div>

  <div class="hcont">
    <div>
      <div class="hbadge"><b></b>Визовое агентство — Алматы</div>
      <h1>Помощь<br>в получении<br><em>визы</em></h1>
      <p class="hdesc">Профессиональная помощь в получении виз любой сложности. Желтоксан 111А — мы берём на себя всё, чтобы вы просто наслаждались путешествием.</p>
      <div class="hstats">
        <div><div class="sn">1000+</div><div class="sl">Виз в год</div></div>
        <div><div class="sn">98%</div><div class="sl">Одобрений</div></div>
        <div><div class="sn">5 лет</div><div class="sl">Опыта</div></div>
        <div><div class="sn">30+</div><div class="sl">Стран</div></div>
      </div>
    </div>
    <div class="fcard">
      {done ? (
        <div class="swrap">
          <div class="sico">✓</div>
          <div class="sttl">Спасибо!</div>
          <p class="stxt">Ваша заявка получена.<br>Мы свяжемся с вами в ближайшее время.</p>
          <a href="/" class="sback">← Вернуться</a>
        </div>
      ) : (
        <>
          <div class="ft">Оставить заявку</div>
          <div class="fs">Консультация бесплатна</div>
          <form method="POST" autocomplete="off">
            <div class="ig"><input type="text" name="name" placeholder="Ваше имя" required /></div>
            <div class="ig"><input type="text" name="phone" placeholder="Номер телефона" required /></div>
            <div class="ig">
              <select name="country" required>
                <option value="" disabled selected>Направление</option>
                <option>ШЕНГЕН</option>
                <option>США</option>
                <option>ДРУГОЕ</option>
              </select>
            </div>
            <button type="submit" class="fbtn">Отправить заявку</button>
          </form>
          <p class="fnote">Ответим в течение 1 рабочего часа</p>
        </>
      )}
    </div>
  </div>
</section>

<section class="sec" id="why">
  <div class="stag">Наши преимущества</div>
  <h2 class="sectitle">Почему выбирают <span>нас</span></h2>
  <div class="why-grid">
    <div class="why-card"><span class="why-icon">🏆</span><div class="why-num">98%</div><div class="why-label">Одобрений</div></div>
    <div class="why-card"><span class="why-icon">⚡</span><div class="why-num">1-3 дня</div><div class="why-label">Подготовка</div></div>
    <div class="why-card"><span class="why-icon">🛡️</span><div class="why-num">100%</div><div class="why-label">Гарантия</div></div>
    <div class="why-card"><span class="why-icon">🌍</span><div class="why-num">30+</div><div class="why-label">Стран</div></div>
  </div>
</section>

<section class="sec dark" id="contacts">
  <div class="stag">Найти нас</div>
  <h2 class="sectitle">Наш <span>Офис</span></h2>
  <div class="cgrid">
    <div>
      <div class="cb"><div class="clabel">Адрес</div><div class="cval">ул. Желтоксан, 111А, офис 1</div></div>
      <div class="cb"><div class="clabel">Телефон</div><div class="cval">+7 778 004 44 13</div></div>
    </div>
    <div class="mapbox">
      <iframe src="https://yandex.ru/map-widget/v1/?ll=76.939223%2C43.254714&z=16&pt=76.939223%2C43.254714,pm2blm" allowfullscreen="true"></iframe>
    </div>
  </div>
</section>

<footer>
  <div class="fcopy">© 2026 BON VOYAGE — Алматы, Желтоксан 111А</div>
</footer>

<script is:inline>
  function toggleNav(){document.getElementById('nav').classList.toggle('open')}
  
  const obs=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){x.target.style.opacity='1';x.target.style.transform='translateY(0)'}})},{threshold:.08});
  document.querySelectorAll('.why-card,.fcard').forEach(el=>{
    el.style.opacity='0';el.style.transform='translateY(20px)';
    el.style.transition='opacity .5s ease,transform .5s ease';obs.observe(el);
  });
</script>
</body>
</html>