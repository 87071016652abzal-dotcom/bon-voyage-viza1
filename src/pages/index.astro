---
export const prerender = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const name = data.get("name") || "Не указано";
    const phone = data.get("phone") || "Не указано";
    const country = data.get("country") || "Не указано";

    const token = import.meta.env.TELEGRAM_BOT_TOKEN || import.meta.env.TELEGRAM_TOKEN;
    const chatId = import.meta.env.TELEGRAM_CHAT_ID;

    if (!token || !chatId) {
      console.error("ОШИБКА: Ключи Telegram не найдены в Environment Variables Vercel");
    }

    const text = `🚀 НОВАЯ ЗАЯВКА!\n👤 Имя: ${name}\n📞 Тел: ${phone}\n🌍 Куда: ${country}`;

    const response = await fetch(`https://api.telegram.org/bot${token}/sendMessage`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ chat_id: chatId, text: text }),
    });

    if (response.ok) {
      return Astro.redirect("/?done=true");
    } else {
      const errorData = await response.json();
      console.error("Ошибка от Telegram API:", errorData);
    }
  } catch (e) {
    console.error("Критическая ошибка на сервере:", e);
  }
}

const done = Astro.url.searchParams.get("done");
---

<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BON VOYAGE | Визовый центр в Алматы</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --o: #e8751a;
      --o2: #ff9040;
      --og: rgba(232,117,26,0.25);
      --blue: #1a6bb5;
      --blue2: #2585d4;
      --bg: #0b1525;
      --bg2: #0e1d35;
      --card: rgba(13,27,52,0.93);
      --brd: rgba(50,100,180,0.22);
      --txt: #deeaff;
      --mt: #6a90bb;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--txt);font-family:'Montserrat',sans-serif;overflow-x:hidden}

    /* ══ HEADER ══ */
    header{
      position:fixed;top:0;width:100%;z-index:1000;
      display:flex;justify-content:space-between;align-items:center;
      padding:12px 6%;
      background:rgba(8,16,32,0.97);
      backdrop-filter:blur(14px);
      border-bottom:1px solid var(--brd);
    }

    /* SVG inline logo — гармонирует с цветами сайта */
    .logo{display:flex;align-items:center;gap:11px;cursor:pointer;text-decoration:none}
    .logo-icon{width:46px;height:46px;flex-shrink:0}
    .logo-text{display:flex;flex-direction:column;line-height:1}
    .logo-bon{font-size:20px;font-weight:900;letter-spacing:.05em;color:#fff}
    .logo-voyage{font-size:11px;font-weight:600;letter-spacing:.28em;color:var(--mt);text-transform:uppercase;margin-top:1px}

    nav{display:flex;align-items:center;gap:32px}
    nav a{color:var(--mt);text-decoration:none;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;transition:color .3s}
    nav a:hover{color:var(--o)}
    .nbtn{
      background:var(--o);color:#fff!important;padding:9px 22px;border-radius:3px;
      font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
      text-decoration:none;box-shadow:0 0 16px var(--og);
      transition:background .3s,box-shadow .3s!important;
    }
    .nbtn:hover{background:var(--o2)!important;box-shadow:0 0 26px var(--og)!important}

    /* ══ HERO ══ */
    .hero{
      position:relative;min-height:100vh;
      display:flex;align-items:center;
      padding:120px 6% 70px;overflow:hidden;
    }

    /* World map — SVG через img тег с прозрачностью */
    .wmap-bg{
      position:absolute;inset:0;z-index:0;
      background:
        url('https://upload.wikimedia.org/wikipedia/commons/thumb/8/80/World_map_-_low_resolution.svg/2560px-World_map_-_low_resolution.svg.png')
        55% 48% / 95% auto no-repeat;
      opacity:0.13;
      filter:sepia(1) hue-rotate(185deg) saturate(4) brightness(1.4);
    }

    /* dark blue base */
    .wgrad{
      position:absolute;inset:0;z-index:1;
      background:
        radial-gradient(ellipse 65% 85% at 55% 48%, rgba(20,50,105,0.45) 0%,transparent 70%),
        linear-gradient(108deg, rgba(11,21,37,0.95) 0%, rgba(11,21,37,0.45) 48%, rgba(11,21,37,0.88) 100%);
    }

    /* grid */
    .wgrid{
      position:absolute;inset:0;z-index:2;
      background-image:
        linear-gradient(rgba(40,90,170,.055) 1px,transparent 1px),
        linear-gradient(90deg,rgba(40,90,170,.055) 1px,transparent 1px);
      background-size:55px 55px;
    }

    /* diagonal stripes */
    .wstripe{
      position:absolute;top:0;right:0;width:46%;height:100%;z-index:3;pointer-events:none;
      background:linear-gradient(-52deg,
        transparent 28%,
        rgba(232,117,26,.06) 42%,rgba(232,117,26,.14) 47%,
        rgba(232,117,26,.05) 52%,transparent 60%,
        transparent 65%,
        rgba(232,117,26,.04) 70%,rgba(232,117,26,.1) 73%,
        rgba(232,117,26,.02) 77%,transparent 83%
      );
    }

    /* Kazakhstan ring */
    .kzring{
      position:absolute;z-index:3;
      left:59%;top:37%;transform:translate(-50%,-50%);
      width:260px;height:260px;border-radius:50%;
      border:1.5px solid rgba(232,117,26,.55);
      background:radial-gradient(circle,rgba(232,117,26,.17) 0%,rgba(232,117,26,.04) 45%,transparent 70%);
      animation:rpulse 3s ease-in-out infinite;
      pointer-events:none;
    }
    .kzring::after{
      content:'';position:absolute;inset:28px;border-radius:50%;
      border:1px solid rgba(232,117,26,.22);
    }
    @keyframes rpulse{0%,100%{box-shadow:0 0 0 0 rgba(232,117,26,.3)}50%{box-shadow:0 0 0 18px rgba(232,117,26,0)}}

    /* pin */
    .kzpin{
      position:absolute;z-index:4;
      left:59%;top:calc(37% - 22px);transform:translateX(-50%);
      pointer-events:none;
    }
    .kzpin svg{filter:drop-shadow(0 0 8px rgba(232,117,26,.8))}

    /* connection lines */
    .svglines{position:absolute;inset:0;width:100%;height:100%;z-index:3;pointer-events:none}

    /* data panels */
    .dpanels{
      position:absolute;right:4.5%;top:50%;transform:translateY(-50%);
      z-index:5;display:flex;flex-direction:column;gap:10px;pointer-events:none;
    }
    .dp{
      background:rgba(9,20,42,.88);border:1px solid rgba(50,100,180,.3);
      border-left:3px solid var(--o);padding:9px 15px;min-width:155px;
      backdrop-filter:blur(8px);border-radius:2px;
    }
    .dp-l{font-size:9px;font-weight:600;letter-spacing:.11em;text-transform:uppercase;color:var(--mt);margin-bottom:5px}
    .dp-bar{height:3px;background:rgba(50,100,180,.18);border-radius:2px;margin-bottom:4px;overflow:hidden}
    .dp-fill{height:100%;background:linear-gradient(90deg,var(--o),var(--o2));border-radius:2px}
    .dp-v{font-size:12px;font-weight:700;color:var(--txt)}

    /* hero content */
    .hcont{
      position:relative;z-index:5;
      display:grid;grid-template-columns:1fr 385px;
      gap:56px;width:100%;align-items:center;
    }

    .hbadge{
      display:inline-flex;align-items:center;gap:9px;
      background:rgba(232,117,26,.12);border:1px solid rgba(232,117,26,.4);
      padding:6px 14px;border-radius:2px;
      font-size:11px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;
      color:var(--o2);margin-bottom:20px;animation:up .7s .1s ease both;
    }
    .hbadge b{
      display:inline-block;width:7px;height:7px;border-radius:50%;
      background:var(--o);box-shadow:0 0 7px var(--o);animation:blink 2s infinite;
    }
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

    h1{font-size:clamp(30px,4.2vw,65px);font-weight:900;line-height:1.06;text-transform:uppercase;animation:up .7s .2s ease both}
    h1 em{font-style:normal;color:var(--o);text-shadow:0 0 32px rgba(232,117,26,.4)}

    .hdesc{
      font-size:14px;line-height:1.8;color:var(--mt);
      margin-top:20px;max-width:470px;
      border-left:3px solid var(--o);padding-left:15px;
      animation:up .7s .35s ease both;
    }

    .hstats{display:flex;gap:34px;margin-top:38px;animation:up .7s .5s ease both}
    .sn{font-size:35px;font-weight:900;color:var(--o);line-height:1;text-shadow:0 0 16px var(--og)}
    .sl{font-size:10px;font-weight:700;letter-spacing:.1em;color:var(--mt);text-transform:uppercase;margin-top:5px}

    @keyframes up{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

    /* ══ FORM ══ */
    .fcard{
      background:var(--card);
      border:1px solid var(--brd);border-top:3px solid var(--o);
      padding:34px 30px;backdrop-filter:blur(18px);
      box-shadow:0 20px 55px rgba(0,0,0,.55),0 0 22px rgba(232,117,26,.06);
      border-radius:4px;animation:up .7s .3s ease both;
    }
    .ft{font-size:18px;font-weight:800;text-transform:uppercase;letter-spacing:.05em;text-align:center;margin-bottom:4px}
    .fs{text-align:center;font-size:11px;font-weight:600;letter-spacing:.12em;color:var(--o);text-transform:uppercase;margin-bottom:22px}

    .ig{margin-bottom:11px}
    .ig input,.ig select{
      width:100%;background:rgba(255,255,255,.04);
      border:1px solid rgba(60,120,200,.28);color:var(--txt);
      padding:13px 14px;font-family:'Montserrat',sans-serif;
      font-size:13px;font-weight:500;outline:none;
      transition:border-color .3s,background .3s;-webkit-appearance:none;border-radius:3px;
    }
    .ig input::placeholder{color:var(--mt)}
    .ig input:focus,.ig select:focus{border-color:var(--o);background:rgba(232,117,26,.05)}
    .ig select option{background:#0d1f3c;color:var(--txt)}

    .fbtn{
      width:100%;background:var(--o);color:#fff;border:none;
      padding:15px;font-family:'Montserrat',sans-serif;
      font-size:13px;font-weight:800;letter-spacing:.13em;text-transform:uppercase;
      cursor:pointer;margin-top:4px;border-radius:3px;
      box-shadow:0 4px 16px var(--og);
      transition:background .3s,box-shadow .3s,transform .15s;
    }
    .fbtn:hover{background:var(--o2);box-shadow:0 6px 26px rgba(232,117,26,.5);transform:translateY(-2px)}
    .fbtn:active{transform:translateY(0)}
    .fnote{text-align:center;font-size:10px;letter-spacing:.07em;color:var(--mt);margin-top:9px}

    /* success */
    .swrap{text-align:center;padding:16px 0}
    .sico{width:60px;height:60px;border:2px solid var(--o);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:24px;color:var(--o);box-shadow:0 0 26px var(--og)}
    .sttl{font-size:24px;font-weight:900;text-transform:uppercase;color:var(--o);margin-bottom:8px}
    .stxt{color:var(--mt);font-size:14px;line-height:1.7}
    .sback{display:inline-block;margin-top:18px;color:var(--o);text-decoration:none;font-size:11px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;border-bottom:1px solid var(--o);padding-bottom:2px}

    /* ══ DIVIDER ══ */
    .divl{height:1px;background:linear-gradient(90deg,transparent,rgba(232,117,26,.35),transparent)}

    /* ══ SERVICES ══ */
    .services{padding:85px 6%;background:var(--bg2)}
    .stag{display:inline-flex;align-items:center;gap:9px;font-size:11px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--o);margin-bottom:11px}
    .stag::before{content:'';width:24px;height:2px;background:var(--o)}
    .sectitle{font-size:clamp(25px,3.2vw,42px);font-weight:900;text-transform:uppercase;line-height:1.1;margin-bottom:46px}
    .sectitle span{color:var(--o)}

    .sgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
    .sc{background:rgba(14,30,62,.85);border:1px solid var(--brd);padding:36px 28px;border-radius:4px;position:relative;overflow:hidden;transition:border-color .3s,transform .3s,box-shadow .3s}
    .sc::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--o),transparent);transform:scaleX(0);transform-origin:left;transition:transform .4s}
    .sc:hover{border-color:rgba(232,117,26,.4);transform:translateY(-5px);box-shadow:0 14px 34px rgba(0,0,0,.4),0 0 22px rgba(232,117,26,.1)}
    .sc:hover::before{transform:scaleX(1)}
    .scn{font-size:48px;font-weight:900;color:rgba(232,117,26,.1);line-height:1;margin-bottom:12px;transition:color .3s}
    .sc:hover .scn{color:rgba(232,117,26,.2)}
    .scname{font-size:20px;font-weight:800;text-transform:uppercase;letter-spacing:.04em;color:var(--txt);margin-bottom:9px}
    .scdesc{font-size:13px;line-height:1.75;color:var(--mt)}
    .sctag{display:flex;align-items:center;gap:6px;margin-top:16px;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--o)}
    .sctag::before{content:'→'}

    /* ══ CONTACTS ══ */
    .contacts{padding:85px 6%;background:var(--bg)}
    .cgrid{display:grid;grid-template-columns:1fr 2fr;gap:60px;margin-top:46px;align-items:start}
    .cb{margin-bottom:30px}
    .cb:last-child{margin-bottom:0}
    .clabel{font-size:10px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--o);margin-bottom:7px}
    .cval{font-size:16px;font-weight:600;line-height:1.5;color:var(--txt)}
    .csub{font-size:12px;color:var(--mt);margin-top:3px}

    .mapbox{position:relative;height:400px;overflow:hidden;border:1px solid var(--brd);border-radius:4px;box-shadow:0 0 32px rgba(232,117,26,.05)}
    .mapbox::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--o),var(--o2),transparent);z-index:2}
    .mapbox iframe{width:100%;height:100%;border:none;filter:saturate(.22) brightness(.6) hue-rotate(192deg)}

    /* ══ FOOTER ══ */
    footer{padding:22px 6%;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--brd);background:rgba(5,11,22,.97);gap:20px}
    .flogo{display:flex;align-items:center;gap:10px;text-decoration:none}
    .flogo-text{display:flex;flex-direction:column;line-height:1}
    .flogo-bon{font-size:16px;font-weight:900;letter-spacing:.05em;color:#fff}
    .flogo-voyage{font-size:9px;font-weight:600;letter-spacing:.28em;color:var(--mt);text-transform:uppercase;margin-top:1px}
    .fcopy{font-size:12px;color:var(--mt);font-weight:500}

    /* ══ BURGER ══ */
    .burger{display:none;flex-direction:column;gap:5px;cursor:pointer}
    .burger span{width:24px;height:2px;background:var(--o);display:block}

    /* ══ RESPONSIVE ══ */
    @media(max-width:1100px){
      .hcont{grid-template-columns:1fr;gap:42px}
      .kzring,.kzpin,.dpanels,.wstripe{display:none}
      .fcard{max-width:500px;width:100%}
      .sgrid{grid-template-columns:1fr}
      .cgrid{grid-template-columns:1fr;gap:40px}
    }
    @media(max-width:768px){
      header{padding:11px 5%}
      nav{display:none}
      nav.open{display:flex;flex-direction:column;position:fixed;inset:0;background:rgba(8,16,32,.99);align-items:center;justify-content:center;gap:26px;z-index:999}
      nav.open a{font-size:15px;color:var(--txt)}
      .burger{display:flex;z-index:1001}
      .hero{padding:92px 5% 52px}
      h1{font-size:clamp(28px,8vw,42px)}
      .hstats{gap:22px;flex-wrap:wrap}
      .services{padding:62px 5%}
      .sc{padding:26px 20px}
      .contacts{padding:62px 5%}
      .mapbox{height:240px}
      .fcard{padding:28px 18px}
      footer{flex-direction:column;text-align:center;padding:18px 5%;gap:10px}
    }
  </style>
</head>
<body>

<header>
  <!-- Логотип в стиле сайта: самолёт SVG + текст в цветах сайта -->
  <a class="logo" href="#home" onclick="window.scrollTo(0,0)">
    <svg class="logo-icon" viewBox="0 0 46 46" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Orbit ring -->
      <ellipse cx="23" cy="23" rx="20" ry="9" stroke="#1a6bb5" stroke-width="1.5" fill="none" transform="rotate(-30 23 23)" opacity="0.7"/>
      <ellipse cx="23" cy="23" rx="20" ry="9" stroke="#e8751a" stroke-width="1.2" fill="none" transform="rotate(-30 23 23) scaleX(0.4)" opacity="0.5"/>
      <!-- Plane -->
      <g transform="translate(23,23) rotate(-35) translate(-8,-5)">
        <path d="M0,5 L14,2 L16,5 L14,8 Z" fill="#ffffff"/>
        <path d="M4,5 L0,0 L2,5 Z" fill="#deeaff" opacity="0.8"/>
        <path d="M4,5 L0,10 L2,5 Z" fill="#deeaff" opacity="0.8"/>
        <path d="M11,5 L9,3 L10,5 Z" fill="#e8751a"/>
      </g>
      <!-- Glow dot -->
      <circle cx="23" cy="23" r="3" fill="#e8751a" opacity="0.6"/>
    </svg>
    <div class="logo-text">
      <span class="logo-bon">BON <span style="color:var(--o)">VOYAGE</span></span>
      <span class="logo-voyage">Визовый центр</span>
    </div>
  </a>

  <nav id="nav">
    <a href="#home">Главная</a>
    <a href="#services">Услуги</a>
    <a href="#contacts">Контакты</a>
    <a href="#home" class="nbtn">Оставить заявку</a>
  </nav>
  <div class="burger" id="burger" onclick="toggleNav()">
    <span></span><span></span><span></span>
  </div>
</header>

<!-- ══ HERO ══ -->
<section class="hero" id="home">
  <div class="wmap-bg"></div>
  <div class="wgrad"></div>
  <div class="wgrid"></div>
  <div class="wstripe"></div>
  <div class="kzring"></div>

  <!-- Казахстан pin -->
  <div class="kzpin">
    <svg width="16" height="22" viewBox="0 0 16 22">
      <path d="M8 0C3.58 0 0 3.58 0 8c0 5.5 8 14 8 14s8-8.5 8-14c0-4.42-3.58-8-8-8z" fill="#e8751a"/>
      <circle cx="8" cy="8" r="3" fill="#fff"/>
    </svg>
  </div>

  <!-- SVG connection lines -->
  <svg class="svglines" viewBox="0 0 1440 900" preserveAspectRatio="none">
    <defs>
      <filter id="glow"><feGaussianBlur stdDeviation="2.5" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
    </defs>
    <line x1="850" y1="340" x2="230" y2="305" stroke="rgba(232,117,26,0.3)" stroke-width="1" stroke-dasharray="5,7"/>
    <line x1="850" y1="340" x2="430" y2="215" stroke="rgba(232,117,26,0.24)" stroke-width="1" stroke-dasharray="5,8"/>
    <line x1="850" y1="340" x2="300" y2="480" stroke="rgba(232,117,26,0.2)" stroke-width="1" stroke-dasharray="5,9"/>
    <line x1="850" y1="340" x2="1150" y2="245" stroke="rgba(232,117,26,0.24)" stroke-width="1" stroke-dasharray="5,7"/>
    <line x1="850" y1="340" x2="1050" y2="410" stroke="rgba(232,117,26,0.22)" stroke-width="1" stroke-dasharray="5,7"/>
    <line x1="850" y1="340" x2="650" y2="510" stroke="rgba(232,117,26,0.18)" stroke-width="1" stroke-dasharray="5,9"/>
    <circle cx="230" cy="305" r="3.5" fill="rgba(232,117,26,0.6)" filter="url(#glow)"/>
    <circle cx="430" cy="215" r="3.5" fill="rgba(232,117,26,0.55)" filter="url(#glow)"/>
    <circle cx="300" cy="480" r="3" fill="rgba(232,117,26,0.45)"/>
    <circle cx="1150" cy="245" r="3.5" fill="rgba(232,117,26,0.55)" filter="url(#glow)"/>
    <circle cx="1050" cy="410" r="3" fill="rgba(232,117,26,0.45)"/>
    <circle cx="850" cy="340" r="6" fill="var(--o)" filter="url(#glow)"/>
  </svg>

  <!-- Data panels -->
  <div class="dpanels">
    <div class="dp">
      <div class="dp-l">Шенген · одобрений</div>
      <div class="dp-bar"><div class="dp-fill" style="width:94%"></div></div>
      <div class="dp-v">94%</div>
    </div>
    <div class="dp">
      <div class="dp-l">США · одобрений</div>
      <div class="dp-bar"><div class="dp-fill" style="width:87%"></div></div>
      <div class="dp-v">87%</div>
    </div>
    <div class="dp">
      <div class="dp-l">Азия · одобрений</div>
      <div class="dp-bar"><div class="dp-fill" style="width:98%"></div></div>
      <div class="dp-v">98%</div>
    </div>
  </div>

  <div class="hcont">
    <div>
      <div class="hbadge"><b></b>Визовый центр — Алматы</div>
