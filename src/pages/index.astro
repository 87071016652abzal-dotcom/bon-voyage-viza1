---
export const prerender = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const name = data.get("name") || "Не указано";
    const phone = data.get("phone") || "Не указано";
    const country = data.get("country") || "Не указано";

    const token = import.meta.env.TELEGRAM_BOT_TOKEN || import.meta.env.TELEGRAM_TOKEN;
    const chatId = import.meta.env.TELEGRAM_CHAT_ID;

    if (!token || !chatId) {
      console.error("ОШИБКА: Ключи Telegram не найдены в Environment Variables Vercel");
    }

    const text = `🚀 НОВАЯ ЗАЯВКА!\n👤 Имя: ${name}\n📞 Тел: ${phone}\n🌍 Куда: ${country}`;

    const response = await fetch(`https://api.telegram.org/bot${token}/sendMessage`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ chat_id: chatId, text: text }),
    });

    if (response.ok) {
      return Astro.redirect("/?done=true");
    } else {
      const errorData = await response.json();
      console.error("Ошибка от Telegram API:", errorData);
    }
  } catch (e) {
    console.error("Критическая ошибка на сервере:", e);
  }
}

const done = Astro.url.searchParams.get("done");
---

<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BON VOYAGE | Визовый центр в Алматы</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --orange: #f07020;
      --orange-light: #ff9040;
      --orange-glow: rgba(240,112,32,0.3);
      --blue-dark: #0a1628;
      --blue-mid: #0d1f3c;
      --blue-card: #0f2347;
      --blue-border: rgba(60,120,200,0.25);
      --text: #e8f0ff;
      --muted: #7a9cc0;
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--blue-dark);
      color: var(--text);
      font-family: 'Montserrat', sans-serif;
      overflow-x: hidden;
    }

    /* Diagonal stripe overlay */
    body::after {
      content: '';
      position: fixed; inset: 0;
      background: repeating-linear-gradient(
        -55deg, transparent, transparent 80px,
        rgba(255,255,255,0.01) 80px, rgba(255,255,255,0.01) 81px
      );
      pointer-events: none; z-index: 0;
    }

    /* HEADER */
    header {
      position: fixed; top: 0; width: 100%;
      display: flex; justify-content: space-between; align-items: center;
      padding: 14px 6%;
      background: rgba(10,22,40,0.96);
      backdrop-filter: blur(16px);
      z-index: 1000;
      border-bottom: 1px solid var(--blue-border);
      animation: fadeDown 0.6s ease both;
    }

    @keyframes fadeDown {
      from { opacity: 0; transform: translateY(-16px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .logo { display: flex; align-items: center; cursor: pointer; }
    .logo img { height: 46px; width: auto; object-fit: contain; }

    nav { display: flex; align-items: center; gap: 36px; }
    nav a {
      color: var(--muted); text-decoration: none;
      font-size: 12px; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase;
      transition: color 0.3s;
    }
    nav a:hover { color: var(--orange); }

    .nav-cta {
      background: var(--orange); color: #fff !important;
      padding: 10px 24px; font-size: 12px; font-weight: 700;
      letter-spacing: 0.08em; text-transform: uppercase;
      text-decoration: none; border-radius: 2px;
      transition: background 0.3s, box-shadow 0.3s !important;
      box-shadow: 0 0 20px var(--orange-glow);
    }
    .nav-cta:hover { background: var(--orange-light) !important; box-shadow: 0 0 30px var(--orange-glow) !important; }

    /* HERO */
    .hero {
      position: relative; min-height: 100vh;
      display: flex; align-items: center;
      padding: 130px 6% 80px; overflow: hidden;
    }

    .hero-bg {
      position: absolute; inset: 0;
      background: url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&q=80&w=2072') center/cover no-repeat;
      filter: brightness(0.2) saturate(0.4) hue-rotate(190deg);
    }

    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(10,22,40,0.9) 0%, rgba(10,22,40,0.5) 55%, rgba(10,22,40,0.8) 100%);
    }

    /* Diagonal accent lines like reference */
    .hero-diagonal {
      position: absolute; top: 0; right: 0;
      width: 40%; height: 100%;
      background: linear-gradient(-55deg,
        transparent 35%, rgba(240,112,32,0.06) 48%,
        rgba(240,112,32,0.1) 52%, rgba(240,112,32,0.03) 58%, transparent 68%
      );
      pointer-events: none;
    }
    .hero-diagonal2 {
      position: absolute; top: 0; right: 0;
      width: 25%; height: 100%;
      background: linear-gradient(-55deg,
        transparent 40%, rgba(240,112,32,0.04) 52%,
        rgba(240,112,32,0.08) 56%, rgba(240,112,32,0.02) 62%, transparent 72%
      );
      pointer-events: none;
    }

    /* Orange glow circle like reference */
    .hero-glow {
      position: absolute; right: 18%; top: 50%; transform: translateY(-50%);
      width: 380px; height: 380px; border-radius: 50%;
      background: radial-gradient(circle, rgba(240,112,32,0.12) 0%, transparent 65%);
      border: 1px solid rgba(240,112,32,0.35);
      pointer-events: none;
    }
    .hero-glow::after {
      content: ''; position: absolute; inset: 25px;
      border-radius: 50%; border: 1px solid rgba(240,112,32,0.15);
    }

    .hero-content {
      position: relative; z-index: 1;
      display: grid; grid-template-columns: 1fr 400px;
      gap: 70px; width: 100%; align-items: center;
    }

    .hero-badge {
      display: inline-flex; align-items: center; gap: 10px;
      background: rgba(240,112,32,0.12);
      border: 1px solid rgba(240,112,32,0.4);
      padding: 7px 16px; border-radius: 2px;
      font-size: 11px; font-weight: 700;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--orange-light); margin-bottom: 24px;
      animation: fadeUp 0.7s 0.1s ease both;
    }
    .hero-badge::before {
      content: ''; width: 7px; height: 7px; border-radius: 50%;
      background: var(--orange); box-shadow: 0 0 8px var(--orange);
      animation: blink 2s infinite;
    }
    @keyframes blink { 0%,100% { opacity:1; } 50% { opacity:0.3; } }

    .hero-title {
      font-size: clamp(34px, 5vw, 70px);
      font-weight: 900; line-height: 1.05;
      text-transform: uppercase; letter-spacing: -0.01em;
      animation: fadeUp 0.7s 0.2s ease both;
    }
    .hero-title span {
      color: var(--orange);
      text-shadow: 0 0 40px rgba(240,112,32,0.4);
    }

    .hero-desc {
      font-size: 15px; line-height: 1.75; color: var(--muted);
      margin-top: 24px; max-width: 500px; font-weight: 400;
      border-left: 3px solid var(--orange); padding-left: 18px;
      animation: fadeUp 0.7s 0.35s ease both;
    }

    .hero-stats {
      display: flex; gap: 40px; margin-top: 44px;
      animation: fadeUp 0.7s 0.5s ease both;
    }
    .stat-num {
      font-size: 38px; font-weight: 900; color: var(--orange); line-height: 1;
      text-shadow: 0 0 20px var(--orange-glow);
    }
    .stat-label {
      font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
      color: var(--muted); text-transform: uppercase; margin-top: 6px;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* FORM */
    .form-card {
      background: rgba(13,31,60,0.94);
      border: 1px solid var(--blue-border);
      border-top: 3px solid var(--orange);
      padding: 40px 36px;
      backdrop-filter: blur(16px);
      animation: fadeUp 0.7s 0.3s ease both;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 30px rgba(240,112,32,0.06);
      border-radius: 4px;
    }

    .form-title {
      font-size: 20px; font-weight: 800;
      text-transform: uppercase; letter-spacing: 0.05em;
      text-align: center; margin-bottom: 6px;
    }
    .form-subtitle {
      text-align: center; font-size: 11px; font-weight: 600;
      letter-spacing: 0.12em; color: var(--orange);
      text-transform: uppercase; margin-bottom: 28px;
    }

    .input-group { margin-bottom: 14px; }
    .input-group input,
    .input-group select {
      width: 100%;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(60,120,200,0.3);
      color: var(--text);
      padding: 14px 16px;
      font-family: 'Montserrat', sans-serif;
      font-size: 13px; font-weight: 500;
      outline: none;
      transition: border-color 0.3s, background 0.3s;
      -webkit-appearance: none; border-radius: 2px;
    }
    .input-group input::placeholder { color: var(--muted); }
    .input-group input:focus, .input-group select:focus {
      border-color: var(--orange); background: rgba(240,112,32,0.05);
    }
    .input-group select option { background: #0d1f3c; color: var(--text); }

    .btn-submit {
      width: 100%; background: var(--orange); color: #fff; border: none;
      padding: 16px; font-family: 'Montserrat', sans-serif;
      font-size: 13px; font-weight: 800; letter-spacing: 0.15em;
      text-transform: uppercase; cursor: pointer; margin-top: 6px;
      border-radius: 2px;
      transition: background 0.3s, box-shadow 0.3s, transform 0.15s;
      box-shadow: 0 4px 20px var(--orange-glow);
    }
    .btn-submit:hover {
      background: var(--orange-light);
      box-shadow: 0 6px 30px rgba(240,112,32,0.5);
      transform: translateY(-2px);
    }
    .btn-submit:active { transform: translateY(0); }

    .form-note {
      text-align: center; font-size: 10px;
      letter-spacing: 0.08em; color: var(--muted); margin-top: 12px;
    }

    /* SUCCESS */
    .success-wrap { text-align: center; padding: 20px 0; }
    .success-icon {
      width: 64px; height: 64px;
      border: 2px solid var(--orange); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 20px; font-size: 26px; color: var(--orange);
      box-shadow: 0 0 30px var(--orange-glow);
    }
    .success-title {
      font-size: 26px; font-weight: 900; text-transform: uppercase;
      color: var(--orange); margin-bottom: 10px;
    }
    .success-text { color: var(--muted); font-size: 14px; line-height: 1.7; }
    .success-back {
      display: inline-block; margin-top: 24px; color: var(--orange);
      text-decoration: none; font-size: 12px; font-weight: 700;
      letter-spacing: 0.15em; text-transform: uppercase;
      border-bottom: 1px solid var(--orange); padding-bottom: 2px;
    }

    /* DIVIDER */
    .divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(240,112,32,0.4), transparent);
    }

    /* SERVICES */
    .services { padding: 100px 6%; background: var(--blue-mid); position: relative; }

    .section-tag {
      display: inline-flex; align-items: center; gap: 10px;
      font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--orange); margin-bottom: 14px;
    }
    .section-tag::before { content: ''; width: 28px; height: 2px; background: var(--orange); }

    .section-title {
      font-size: clamp(28px, 3.5vw, 46px); font-weight: 900;
      text-transform: uppercase; line-height: 1.1; margin-bottom: 56px;
    }
    .section-title span { color: var(--orange); }

    .services-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
    }

    .service-card {
      background: rgba(15,35,71,0.85); border: 1px solid var(--blue-border);
      padding: 40px 32px; position: relative; overflow: hidden;
      transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
      border-radius: 4px;
    }
    .service-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--orange), transparent);
      transform: scaleX(0); transform-origin: left; transition: transform 0.4s;
    }
    .service-card:hover {
      border-color: rgba(240,112,32,0.4); transform: translateY(-6px);
      box-shadow: 0 16px 40px rgba(0,0,0,0.4), 0 0 30px rgba(240,112,32,0.1);
    }
    .service-card:hover::before { transform: scaleX(1); }

    .service-num {
      font-size: 52px; font-weight: 900;
      color: rgba(240,112,32,0.1); line-height: 1;
      margin-bottom: 16px; transition: color 0.3s;
    }
    .service-card:hover .service-num { color: rgba(240,112,32,0.22); }

    .service-name {
      font-size: 22px; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.05em; color: var(--text); margin-bottom: 12px;
    }
    .service-desc { font-size: 13px; line-height: 1.75; color: var(--muted); }

    .service-footer {
      display: flex; align-items: center; gap: 8px;
      margin-top: 20px; font-size: 11px; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase; color: var(--orange);
    }
    .service-footer::before { content: '→'; }

    /* CONTACTS */
    .contacts { padding: 100px 6%; background: var(--blue-dark); }

    .contacts-grid {
      display: grid; grid-template-columns: 1fr 2fr;
      gap: 70px; margin-top: 56px; align-items: start;
    }

    .contact-block { margin-bottom: 36px; }
    .contact-block:last-child { margin-bottom: 0; }

    .contact-label {
      font-size: 10px; font-weight: 700; letter-spacing: 0.25em;
      text-transform: uppercase; color: var(--orange); margin-bottom: 8px;
    }
    .contact-value { font-size: 18px; font-weight: 600; line-height: 1.5; color: var(--text); }
    .contact-sub { font-size: 12px; color: var(--muted); margin-top: 4px; }

    .map-wrap {
      position: relative; height: 440px; overflow: hidden;
      border: 1px solid var(--blue-border); border-radius: 4px;
      box-shadow: 0 0 40px rgba(240,112,32,0.06);
    }
    .map-wrap::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--orange), var(--orange-light), transparent);
      z-index: 2;
    }
    .map-wrap iframe {
      width: 100%; height: 100%; border: none;
      filter: saturate(0.3) brightness(0.65) hue-rotate(195deg);
    }

    /* FOOTER */
    footer {
      padding: 26px 6%; display: flex;
      justify-content: space-between; align-items: center;
      border-top: 1px solid var(--blue-border);
      background: rgba(6,14,26,0.95); gap: 20px;
    }
    .footer-logo img { height: 36px; width: auto; object-fit: contain; }
    .footer-copy { font-size: 12px; color: var(--muted); font-weight: 500; }

    /* MOBILE */
    .burger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
    .burger span { width: 24px; height: 2px; background: var(--orange); display: block; }

    @media (max-width: 1024px) {
      .hero-content { grid-template-columns: 1fr; gap: 50px; }
      .hero-glow { display: none; }
      .form-card { max-width: 520px; width: 100%; }
      .services-grid { grid-template-columns: 1fr; }
      .contacts-grid { grid-template-columns: 1fr; gap: 50px; }
    }

    @media (max-width: 768px) {
      header { padding: 13px 5%; }
      .logo img { height: 40px; }
      nav { display: none; }
      nav.open {
        display: flex; flex-direction: column;
        position: fixed; inset: 0;
        background: rgba(10,22,40,0.99);
        align-items: center; justify-content: center;
        gap: 28px; z-index: 999;
      }
      nav.open a { font-size: 15px; color: var(--text); }
      .burger { display: flex; z-index: 1001; }

      .hero { padding: 100px 5% 60px; }
      .hero-title { font-size: clamp(30px, 8vw, 46px); }
      .hero-stats { gap: 28px; flex-wrap: wrap; }
      .hero-diagonal, .hero-diagonal2 { display: none; }

      .services { padding: 70px 5%; }
      .service-card { padding: 30px 24px; }

      .contacts { padding: 70px 5%; }
      .map-wrap { height: 280px; }

      .form-card { padding: 32px 22px; }

      footer { flex-direction: column; text-align: center; padding: 22px 5%; gap: 12px; }
      .footer-logo img { height: 30px; }
    }
  </style>
</head>
<body>

  <header>
    <div class="logo" onclick="window.scrollTo(0,0)">
      <img src="/logo.png" alt="Bon Voyage" />
    </div>
    <nav id="nav">
      <a href="#home">Главная</a>
      <a href="#services">Услуги</a>
      <a href="#contacts">Контакты</a>
      <a href="#home" class="nav-cta">Оставить заявку</a>
    </nav>
    <div class="burger" id="burger" onclick="toggleNav()">
      <span></span><span></span><span></span>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero" id="home">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-diagonal"></div>
    <div class="hero-diagonal2"></div>
    <div class="hero-glow"></div>

    <div class="hero-content">
      <div class="hero-text">
        <div class="hero-badge">Визовый центр — Алматы</div>
        <h1 class="hero-title">
          Помощь<br>в получении<br>
          <span>визы</span>
        </h1>
        <p class="hero-desc">
          Профессиональная помощь в получении виз любой сложности.
          Желтоксан 111А — мы берём на себя всё, чтобы вы просто наслаждались путешествием.
        </p>
        <div class="hero-stats">
          <div>
            <div class="stat-num">500+</div>
            <div class="stat-label">Виз в год</div>
          </div>
          <div>
            <div class="stat-num">98%</div>
            <div class="stat-label">Одобрений</div>
          </div>
          <div>
            <div class="stat-num">5 лет</div>
            <div class="stat-label">Опыта</div>
          </div>
        </div>
      </div>

      <div class="form-card">
        {done ? (
          <div class="success-wrap">
            <div class="success-icon">✓</div>
            <div class="success-title">Спасибо!</div>
            <p class="success-text">Ваша заявка получена.<br>Мы свяжемся с вами в ближайшее время.</p>
            <a href="/" class="success-back">← Вернуться</a>
          </div>
        ) : (
          <>
            <div class="form-title">Оставить заявку</div>
            <div class="form-subtitle">Консультация бесплатна</div>
            <form method="POST" autocomplete="off">
              <div class="input-group">
                <input type="text" name="name" placeholder="Ваше имя" autocomplete="one-time-code" required />
              </div>
              <div class="input-group">
                <input type="text" name="phone" placeholder="Номер телефона" autocomplete="one-time-code" required />
              </div>
              <div class="input-group">
                <select name="country" required>
                  <option value="" disabled selected>Куда летим?</option>
                  <option>ШЕНГЕН</option>
                  <option>США</option>
                  <option>КОРЕЯ</option>
                  <option>ЯПОНИЯ</option>
                </select>
              </div>
              <button type="submit" class="btn-submit">Отправить заявку</button>
            </form>
            <p class="form-note">Ответим в течение 1 рабочего часа</p>
          </>
        )}
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- SERVICES -->
  <section class="services" id="services">
    <div class="section-tag">Что мы делаем</div>
    <h2 class="section-title">Наши <span>Услуги</span></h2>

    <div class="services-grid">
      <div class="service-card">
        <div class="service-num">01</div>
        <div class="service-name">Шенген</div>
        <p class="service-desc">Европа стала ближе. Полное сопровождение: запись в консульство, сбор и проверка документов, заполнение анкет.</p>
        <div class="service-footer">Франция · Германия · Италия</div>
      </div>
      <div class="service-card">
        <div class="service-num">02</div>
        <div class="service-name">США</div>
        <p class="service-desc">Заполнение анкеты DS-160, детальная подготовка к собеседованию. Максимальные шансы на одобрение.</p>
        <div class="service-footer">B1 · B2 · F1</div>
      </div>
      <div class="service-card">
        <div class="service-num">03</div>
        <div class="service-name">Азия</div>
        <p class="service-desc">Визы в Японию и Корею. Минимум документов, максимум результата. Оформление в кратчайшие сроки.</p>
        <div class="service-footer">Япония · Корея</div>
      </div>
    </div>
  </section>

  <!-- CONTACTS -->
  <section class="contacts" id="contacts">
    <div class="section-tag">Найти нас</div>
    <h2 class="section-title">Наш <span>Офис</span></h2>

    <div class="contacts-grid">
      <div>
        <div class="contact-block">
          <div class="contact-label">Адрес</div>
          <div class="contact-value">ул. Желтоксан, 111А<br>офис 1</div>
          <div class="contact-sub">угол ул. Толе Би, г. Алматы</div>
        </div>
        <div class="contact-block">
          <div class="contact-label">Телефон</div>
          <div class="contact-value">+7 778 004 44 13</div>
        </div>
        <div class="contact-block">
          <div class="contact-label">График работы</div>
          <div class="contact-value">Пн — Пт</div>
          <div class="contact-sub">09:00 — 18:00</div>
        </div>
      </div>

      <div class="map-wrap">
        <iframe
          src="https://yandex.ru/map-widget/v1/?ll=76.939223%2C43.254714&z=16&pt=76.939223%2C43.254714,pm2blm"
          allowfullscreen="true">
        </iframe>
      </div>
    </div>
  </section>

  <footer>
    <div class="footer-logo">
      <img src="/logo.png" alt="Bon Voyage" />
    </div>
    <div class="footer-copy">© 2026 BON VOYAGE — Алматы, Желтоксан 111А</div>
  </footer>

  <script>
    function toggleNav() {
      document.getElementById('nav').classList.toggle('open');
    }
    document.querySelectorAll('#nav a').forEach(a => {
      a.addEventListener('click', () => {
        document.getElementById('nav').classList.remove('open');
      });
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.service-card, .contact-block').forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      observer.observe(el);
    });
  </script>
</body>
</html>