---
export const prerender = false;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const name = data.get("name") || "Не указано";
    const phone = data.get("phone") || "Не указано";
    const country = data.get("country") || "Не указано";
    const token = import.meta.env.TELEGRAM_BOT_TOKEN || import.meta.env.TELEGRAM_TOKEN;
    const chatId = import.meta.env.TELEGRAM_CHAT_ID;
    const text = `🚀 НОВАЯ ЗАЯВКА!\n👤 Имя: ${name}\n📞 Тел: ${phone}\n🌍 Куда: ${country}`;
    const response = await fetch(`https://api.telegram.org/bot${token}/sendMessage`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ chat_id: chatId, text: text }),
    });
    if (response.ok) {
      return Astro.redirect("/?done=true");
    } else {
      const errorData = await response.json();
      console.error("Ошибка от Telegram API:", errorData);
    }
  } catch (e) {
    console.error("Критическая ошибка на сервере:", e);
  }
}
const done = Astro.url.searchParams.get("done");
---

<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BON VOYAGE | Визовое агентство в Алматы</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --o: #e8751a; /* Оранжевый из лого */
      --o2: #f5a623;
      --blue: #004a99; /* Синий из лого */
      --bg: #2b2d2f; /* Темно-серый фон как на скрине */
      --bg2: #343638;
      --bg3: #222426;
      --card: rgba(45, 47, 49, 0.95);
      --brd: rgba(232, 117, 26, 0.2);
      --txt: #ffffff;
      --mt: #a0a0a0;
      --gold: #b89a5b; /* Золотой для карты */
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--txt);font-family:'Montserrat',sans-serif;overflow-x:hidden}

    /* HEADER */
    header{
      position:fixed;top:0;width:100%;z-index:1000;
      display:flex;justify-content:space-between;align-items:center;
      padding:12px 6%;
      background:rgba(43, 45, 47, 0.98);
      backdrop-filter:blur(14px);
      border-bottom:1px solid rgba(255,255,255,0.05);
    }
    .logo{display:flex;align-items:center;gap:11px;cursor:pointer;text-decoration:none}
    .logo img { height: 50px; width: auto; }
    
    nav{display:flex;align-items:center;gap:24px}
    nav a{color:var(--mt);text-decoration:none;font-size:12px;font-weight:600;text-transform:uppercase;transition:color .3s}
    nav a:hover{color:var(--o)}
    .nbtn{
      background:var(--o);color:#fff!important;padding:10px 22px;border-radius:6px;
      font-size:12px;font-weight:700;text-transform:uppercase;
      text-decoration:none;transition:background .3s!important;
    }
    .nbtn:hover{background:var(--o2)!important;}

    /* HERO */
    .hero{
      position:relative;min-height:100vh;
      display:flex;align-items:center;
      padding:120px 6% 70px;overflow:hidden;
    }
    
    /* КАРТА МИРА */
    .wmap-wrap{position:absolute;right:0;top:50%;transform:translateY(-50%);width:60%;z-index:1;pointer-events:none;}
    .wmap-svg{width:100%;height:auto; shape-rendering: geometricPrecision;}
    
    .hcont{position:relative;z-index:5;display:grid;grid-template-columns:1fr 400px;gap:60px;width:100%;align-items:center}
    h1{font-size:clamp(30px,4.5vw,60px);font-weight:800;line-height:1.1;text-transform:uppercase; margin-bottom: 20px;}
    h1 em{font-style:normal;color:var(--o);}
    .hdesc{font-size:16px;line-height:1.6;color:var(--mt);max-width:500px;margin-bottom:30px;}

    /* СТАТИСТИКА */
    .hstats{display:flex;gap:40px;}
    .sn{font-size:32px;font-weight:800;color:var(--txt);line-height:1;}
    .sl{font-size:11px;font-weight:600;color:var(--o);text-transform:uppercase;margin-top:8px;}

    /* ФОРМА */
    .fcard{background:var(--card);border:1px solid rgba(255,255,255,0.1);padding:40px;border-radius:12px;box-shadow:0 30px 60px rgba(0,0,0,0.4);}
    .ft{font-size:20px;font-weight:800;text-transform:uppercase;margin-bottom:8px;text-align:center}
    .fs{text-align:center;font-size:12px;color:var(--o);margin-bottom:25px;text-transform:uppercase;font-weight:700}
    .ig{margin-bottom:15px}
    .ig input,.ig select{width:100%;background:#3d3f41;border:1px solid #4d4f51;color:#fff;padding:15px;border-radius:6px;outline:none;font-family:'Montserrat',sans-serif;}
    .fbtn{width:100%;background:var(--o);color:#fff;border:none;padding:18px;font-weight:800;text-transform:uppercase;cursor:pointer;border-radius:6px;transition:0.3s;}
    .fbtn:hover{background:var(--o2);transform:translateY(-2px)}

    /* СЕКЦИИ */
    .sec{padding:100px 6%}
    .sec.alt{background:var(--bg2)}
    .sectitle{font-size:36px;font-weight:800;text-transform:uppercase;margin-bottom:50px;text-align:center;}
    .sectitle span{color:var(--o)}

    /* КАРТОЧКИ ПРЕИМУЩЕСТВ */
    .why-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
    .why-card{background:var(--bg3);padding:40px 30px;border-radius:10px;text-align:center;border:1px solid rgba(255,255,255,0.03);}
    .why-num{font-size:36px;font-weight:800;color:var(--o);margin-bottom:10px;}
    .why-label{font-size:14px;font-weight:700;text-transform:uppercase;}

    footer{padding:40px 6%;text-align:center;border-top:1px solid rgba(255,255,255,0.05);color:var(--mt);font-size:13px;}

    @media(max-width:1100px){
      .hcont{grid-template-columns:1fr; text-align:center;}
      .wmap-wrap{opacity:0.2; width:100%;}
      .why-grid{grid-template-columns:repeat(2,1fr)}
      .hdesc{margin: 0 auto 30px;}
      .hstats{justify-content:center;}
      .fcard{max-width:500px; margin: 0 auto;}
    }
  </style>
</head>
<body>

<header>
  <a class="logo" href="#home">
    <img src="/logo-main.png" alt="BON VOYAGE">
  </a>
  <nav id="nav">
    <a href="#home">Главная</a>
    <a href="#services">Услуги</a>
    <a href="#why">Преимущества</a>
    <a href="#contacts">Контакты</a>
    <a href="#home" class="nbtn">Получить консультацию</a>
  </nav>
</header>

<section class="hero" id="home">
  <div class="wmap-wrap">
    <svg class="wmap-svg" viewBox="0 0 1000 500" xmlns="http://www.w3.org/2000/svg">
      <path d="M150,140 L170,130 L210,135 L230,170 L200,210 L170,200 L150,170 Z M420,130 L470,110 L520,120 L550,160 L500,210 L440,190 Z M620,80 C720,60 820,100 850,230 C720,330 620,300 590,260 Z M270,330 L370,320 L420,400 L320,500 L250,450 Z M750,430 L880,410 L920,500 L800,530 Z" fill="var(--gold)" opacity="0.4"/>
      <path d="M580,110 L610,105 L640,115 L650,135 L625,150 L585,145 Z" fill="var(--o)" opacity="1">
        <animate attributeName="opacity" values="0.7;1;0.7" dur="3s" repeatCount="indefinite" />
      </path>
    </svg>
  </div>

  <div class="hcont">
    <div>
      <div class="hbadge">Визовое агентство — Алматы</div>
      <h1>Ваш легкий<br>путь к <em>визе</em></h1>
      <p class="hdesc">Оформление шенгенских и национальных виз по всему миру. Быстро. Надежно. С гарантией.</p>
      <div class="hstats">
        <div><div class="sn">98%</div><div class="sl">Одобрений</div></div>
        <div><div class="sn">10+ лет</div><div class="sl">Опыта</div></div>
        <div><div class="sn">30+</div><div class="sl">Стран</div></div>
      </div>
    </div>

    <div class="fcard">
      {done ? (
        <div style="text-align:center">
          <h2 style="color:var(--o)">Спасибо!</h2>
          <p>Мы свяжемся с вами в ближайшее время.</p>
          <a href="/" style="color:var(--o); display:block; margin-top:20px">← Назад</a>
        </div>
      ) : (
        <form method="POST">
          <div class="ft">Оставить заявку</div>
          <div class="fs">Консультация бесплатна</div>
          <div class="ig"><input type="text" name="name" placeholder="Ваше имя" required /></div>
          <div class="ig"><input type="text" name="phone" placeholder="Номер телефона" required /></div>
          <div class="ig">
            <select name="country">
              <option>Шенген</option>
              <option>США</option>
              <option>Другое</option>
            </select>
          </div>
          <button type="submit" class="fbtn">Получить консультацию</button>
        </form>
      )}
    </div>
  </div>
</section>

<section class="sec alt" id="why">
  <h2 class="sectitle">Почему выбирают <span>Bon Voyage</span>?</h2>
  <div class="why-grid">
    <div class="why-card">
      <div class="why-num">98%</div>
      <div class="why-label">Одобрений</div>
    </div>
    <div class="why-card">
      <div class="why-num">10+ лет</div>
      <div class="why-label">Опыта</div>
    </div>
    <div class="why-card">
      <div class="why-num">Профи</div>
      <div class="why-label">Специалисты</div>
    </div>
    <div class="why-card">
      <div class="why-num">Сжатые</div>
      <div class="why-label">Сроки</div>
    </div>
  </div>
</section>

<footer>
  © 2026 BON VOYAGE — Алматы, Желтоксан 111А
</footer>

</body>
</html>